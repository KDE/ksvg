include($KDE_DOCS/global/qt-module-defaults-online.qdocconf)

project = KSvg
description = A library for rendering SVG-based themes with stylesheet re-coloring and on-disk caching.

documentationinheaders = true

headerdirs = .

headers.fileextensions = "*.qdoc *.h"

outputformats = HTML

depends += \
    kde \
    qtcore \
    qtgui \
    ksvgqml